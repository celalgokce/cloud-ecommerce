<%- include('../header') %>
<div class="page container">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px"><h1 class="page-title" style="margin:0">📊 Admin Dashboard</h1><div><a href="/admin/products" class="btn btn-outline btn-sm" style="margin-right:8px">📦 Ürünler</a><a href="/admin/orders" class="btn btn-outline btn-sm" style="margin-right:8px">🧾 Siparişler</a><a href="/admin/users" class="btn btn-outline btn-sm">👥 Kullanıcılar</a></div></div>

<div style="display:grid;grid-template-columns:repeat(6,1fr);gap:12px;margin-bottom:24px">
<div class="stat-card"><div class="num" style="color:var(--primary)"><%= stats.products || 0 %></div><div class="label">Ürün</div></div>
<div class="stat-card"><div class="num" style="color:var(--green)"><%= stats.orders || 0 %></div><div class="label">Sipariş</div></div>
<div class="stat-card"><div class="num" style="color:var(--orange)"><%= stats.users || 0 %></div><div class="label">Kullanıcı</div></div>
<div class="stat-card"><div class="num" style="color:var(--purple);font-size:20px">₺<%= Number(stats.revenue || 0).toLocaleString('tr-TR') %></div><div class="label">Gelir</div></div>
<div class="stat-card"><div class="num" style="color:var(--yellow)"><%= stats.pending || 0 %></div><div class="label">Bekleyen</div></div>
<div class="stat-card"><div class="num" style="color:var(--cyan)"><%= stats.today_orders || 0 %></div><div class="label">Bugün</div></div>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
<div style="background:var(--white);border-radius:16px;padding:24px;box-shadow:var(--shadow);border:1px solid #e2e8f0">
<h3 style="font-size:16px;margin-bottom:16px">🏆 En Çok Satan Ürünler</h3>
<% if(topProducts.length) { topProducts.forEach((p,i) => { %>
<div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid #f1f5f9"><div><span style="font-size:20px;margin-right:8px"><%= p.emoji %></span><strong><%= p.product_name %></strong></div><div style="text-align:right"><div style="font-weight:700"><%= p.sold %> adet</div><div style="font-size:12px;color:var(--gray)">₺<%= Number(p.revenue).toLocaleString('tr-TR') %></div></div></div>
<% }); } else { %><p style="color:var(--gray)">Henüz satış yok</p><% } %>
</div>

<div style="background:var(--white);border-radius:16px;padding:24px;box-shadow:var(--shadow);border:1px solid #e2e8f0">
<h3 style="font-size:16px;margin-bottom:16px">📂 Kategori Bazlı Satış</h3>
<% if(categorySales.length) { categorySales.forEach(c => { %>
<div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f1f5f9"><div><strong><%= c.category %></strong><span style="margin-left:8px;font-size:12px;color:var(--gray)">(<%= c.sales %> satış)</span></div><div style="font-weight:700">₺<%= Number(c.revenue).toLocaleString('tr-TR') %></div></div>
<% }); } else { %><p style="color:var(--gray)">Veri yok</p><% } %>
</div>
</div>

<div style="background:var(--white);border-radius:16px;padding:24px;margin-top:16px;box-shadow:var(--shadow);border:1px solid #e2e8f0">
<h3 style="font-size:16px;margin-bottom:16px">🕐 Son Siparişler</h3>
<table class="cart-table"><thead><tr><th>#</th><th>Müşteri</th><th>Tutar</th><th>Durum</th><th>Tarih</th></tr></thead><tbody>
<% recentOrders.forEach(o => { %>
<tr><td><strong>#<%= o.order_id %></strong></td><td><%= o.customer_name %></td><td style="font-weight:700">₺<%= Number(o.total_amount).toLocaleString('tr-TR') %></td><td><span class="status status-<%= o.status %>"><%= o.status %></span></td><td style="font-size:12px;color:var(--gray)"><%= new Date(o.created_at).toLocaleDateString('tr-TR') %></td></tr>
<% }); %>
</tbody></table>
</div>
</div>
<%- include('../footer') %>
