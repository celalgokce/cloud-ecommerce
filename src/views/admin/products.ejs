<%- include('../header') %>
<div class="page container">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px"><h1 class="page-title" style="margin:0">📦 Ürün Yönetimi</h1><a href="/admin" class="btn btn-outline btn-sm">← Dashboard</a></div>

<div style="background:var(--white);border-radius:16px;padding:24px;margin-bottom:20px;box-shadow:var(--shadow);border:1px solid #e2e8f0">
<h3 style="margin-bottom:16px">➕ Yeni Ürün Ekle</h3>
<form method="POST" action="/admin/products/add" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
<div class="fg"><label>Ürün Adı</label><input name="product_name" required></div>
<div class="fg"><label>Kategori</label><input name="category" required></div>
<div class="fg"><label>Fiyat (₺)</label><input name="price" type="number" step="0.01" required></div>
<div class="fg"><label>Stok</label><input name="stock" type="number" value="50"></div>
<div class="fg"><label>Emoji</label><input name="emoji" value="📦" maxlength="5"></div>
<div class="fg"><label>Renk</label><select name="color_class"><option value="bg-blue">Mavi</option><option value="bg-purple">Mor</option><option value="bg-green">Yeşil</option><option value="bg-pink">Pembe</option><option value="bg-orange">Turuncu</option><option value="bg-cyan">Cyan</option><option value="bg-yellow">Sarı</option><option value="bg-gray">Gri</option></select></div>
<div class="fg" style="grid-column:1/-1"><label>Açıklama</label><input name="description"></div>
<div style="grid-column:1/-1;display:flex;gap:12px;align-items:center"><label><input type="checkbox" name="featured"> Öne Çıkan</label><button type="submit" class="btn btn-primary">Ürün Ekle</button></div>
</form></div>

<table class="cart-table"><thead><tr><th></th><th>Ürün</th><th>Kategori</th><th>Fiyat</th><th>Stok</th><th>Öne Çıkan</th><th></th></tr></thead><tbody>
<% products.forEach(p => { %>
<tr><td style="font-size:24px"><%= p.emoji %></td><td><strong><%= p.product_name %></strong></td><td><%= p.category %></td><td>₺<%= Number(p.price).toLocaleString('tr-TR') %></td><td><%= p.stock %></td><td><%= p.featured ? '⭐' : '' %></td><td><form method="POST" action="/admin/products/delete/<%= p.product_id %>" onsubmit="return confirm('Silmek istediğinize emin misiniz?')"><button type="submit" class="btn btn-danger btn-sm">Sil</button></form></td></tr>
<% }); %>
</tbody></table>
</div>
<%- include('../footer') %>
