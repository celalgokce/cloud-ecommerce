<%- include('header') %>
<div class="page container">
<h1 class="page-title">🛍️ Tüm Ürünler</h1>
<div class="filters"><form method="GET" action="/products" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;width:100%"><select name="category" onchange="this.form.submit()"><option value="">Tüm Kategoriler</option><% categories.forEach(c => { %><option value="<%= c %>" <%= currentCategory===c?'selected':'' %>><%= c %></option><% }) %></select><select name="sort" onchange="this.form.submit()"><option value="newest" <%= currentSort==='newest'?'selected':'' %>>En Yeni</option><option value="price_asc" <%= currentSort==='price_asc'?'selected':'' %>>Fiyat: Düşükten Yükseğe</option><option value="price_desc" <%= currentSort==='price_desc'?'selected':'' %>>Fiyat: Yüksekten Düşüğe</option><option value="name" <%= currentSort==='name'?'selected':'' %>>A-Z</option></select><input type="text" name="search" placeholder="🔍 Ürün ara..." value="<%= currentSearch %>" style="flex:1;min-width:200px"><button type="submit" class="btn btn-primary btn-sm">Ara</button></form></div>
<div class="product-grid"><% products.forEach(p => { %><div class="product-card"><div class="product-img <%= p.color_class %>"><span><%= p.emoji %></span><% if(p.stock > 0) { %><div class="stock-badge"><%= p.stock %> adet</div><% } %></div><div class="info"><div class="category"><%= p.category %></div><div class="name"><%= p.product_name %></div><div class="desc"><%= p.description %></div><div class="bottom"><div class="price">₺<%= Number(p.price).toLocaleString('tr-TR') %></div><form method="POST" action="/cart/add" style="display:inline"><input type="hidden" name="product_id" value="<%= p.product_id %>"><input type="hidden" name="product_name" value="<%= p.product_name %>"><input type="hidden" name="price" value="<%= p.price %>"><input type="hidden" name="quantity" value="1"><button type="submit" class="btn btn-primary btn-sm">🛒 Ekle</button></form></div></div></div><% }) %></div>
<% if(products.length===0) { %><div class="empty-state"><div class="icon">🔍</div><p>Aradığınız ürün bulunamadı</p><a href="/products" class="btn btn-outline">Tüm Ürünleri Göster</a></div><% } %>
</div>
<%- include('footer') %>
